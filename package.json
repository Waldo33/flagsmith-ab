{
  "name": "flagsmith-ab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "analytics:dev": "node --watch analytics-service/index.js",
    "analytics:start": "node analytics-service/index.js",
    "clickhouse:down": "./scripts/clickhouse-local-down.sh",
    "clickhouse:up": "./scripts/clickhouse-local-up.sh",
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "flagsmith:fallback:pull": "node ./scripts/pull-flagsmith-fallback.mjs",
    "flagsmith:down": "./scripts/flagsmith-local-down.sh",
    "flagsmith:up": "./scripts/flagsmith-local-up.sh",
    "lint": "eslint .",
    "preview": "vite preview",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "stack:up": "docker compose up -d --build"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@flagsmith/flagsmith": "^11.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
